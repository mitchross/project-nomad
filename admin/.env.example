PORT=8080
HOST=localhost
LOG_LEVEL=info
APP_KEY=some_random_key
NODE_ENV=development
SESSION_DRIVER=cookie
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_DATABASE=nomad
DB_PASSWORD=password
DB_SSL=false
REDIS_HOST=localhost
REDIS_PORT=6379
# Storage path for NOMAD content (ZIM files, maps, etc.)
# On Windows dev, use an absolute path like: C:/nomad-storage
# On Linux production, use: /opt/project-nomad/storage
NOMAD_STORAGE_PATH=/opt/project-nomad/storage

# --- LLM Provider Configuration ---
# Provider type: 'ollama' (default) or 'openai' (for llama-cpp, vLLM, or any OpenAI-compatible API)
LLM_PROVIDER=ollama
# Base URL for the LLM API. Required for openai provider. For ollama, falls back to Docker discovery.
# Examples:
#   Ollama: http://localhost:11434
#   llama-cpp: http://localhost:8080/v1
#   vLLM: http://localhost:8000/v1
LLM_HOST=
# API key (most local servers accept any value)
LLM_API_KEY=unused
# Legacy Ollama host (used if LLM_PROVIDER is not set)
OLLAMA_HOST=

# --- Embedding Configuration ---
# Model used for RAG embeddings (must be available on your LLM server)
EMBEDDING_MODEL=nomic-embed-text:v1.5
# Vector dimensions (must match the model and Qdrant collection)
EMBEDDING_DIMENSIONS=768
# Task-specific prefixes for Nomic-style models (leave empty for models that don't use prefixes)
EMBEDDING_SEARCH_DOC_PREFIX=search_document:
EMBEDDING_SEARCH_QUERY_PREFIX=search_query:

# --- Qdrant Vector Database ---
# URL for Qdrant. If not set, falls back to Docker discovery.
QDRANT_HOST=

# --- Companion Service URLs ---
# Set a URL to use a BYO (bring-your-own) external instance.
# Leave empty to use the default Docker-managed service.
KIWIX_URL=
KOLIBRI_URL=
PROTOMAPS_URL=
CYBERCHEF_URL=
FLATNOTES_URL=